{
  "name": "next-convex-starter-app",
  "version": "1.1.0",
  "description": "",
  "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499",
  "main": "index.js",
  "scripts": {
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "dev": "turbo run dev",
    "setup": "node scripts/setup.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "turbo run typecheck",
    "find-deadcode": "fallow dead-code --baseline .fallow/baseline.json",
    "audit": "fallow audit --dead-code-baseline .fallow/baseline.json",
    "code-quality": "fallow",
    "code-quality:fix": "fallow fix --dry-run",
    "e2e": "turbo run e2e",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md,css,scss,yml,mdx}": [
      "prettier --write"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^1.2.2",
    "@eslint/eslintrc": "^3",
    "@types/node": "^20.17.24",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "eslint": "^9.26.0",
    "eslint-config-next": "16.2.3",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^61.5.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-you-might-not-need-an-effect": "^0.9.2",
    "fallow": "^2.85.0",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.0",
    "turbo": "^2.9.15",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@radix-ui/react-tooltip": "^1.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bun",
      "esbuild",
      "sharp",
      "turbo",
      "unrs-resolver"
    ],
    "overrides": {
      "@radix-ui/react-dismissable-layer": "1.1.10"
    }
  }
}
