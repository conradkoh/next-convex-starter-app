{
  "name": "@workspace/webapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -e .env.local -- next dev",
    "build": "next build --turbopack",
    "start": "next start --turbopack",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "e2e": "playwright test --config=tests/e2e/playwright.config.ts",
    "generate:icons": "bun run scripts/generate-icons.ts",
    "generate:icons:all": "bun run scripts/generate-icons.ts --favicon"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@hookform/resolvers": "^5.0.1",
    "@mdx-js/loader": "^3.1.0",
    "@types/luxon": "^3.6.2",
    "@types/mdx": "^2.0.13",
    "@workspace/backend": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.39.1",
    "convex-helpers": "^0.1.118",
    "lucide-react": "^0.511.0",
    "luxon": "^3.6.1",
    "next": "16.2.3",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-day-picker": "10.0.1",
    "react-dom": "19.2.3",
    "react-icons": "^5.5.0",
    "sonner": "^2.0.3",
    "tailwind-merge": "^3.0.2",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@mdx-js/react": "^3.1.0",
    "@next/mdx": "16.2.3",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/ui": "^4.0.6",
    "bun": "^1.3.2",
    "dotenv-cli": "^11.0.0",
    "jsdom": "^27.1.0",
    "playwright": "^1.60.0",
    "png-to-ico": "^2.1.8",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.1",
    "tailwindcss": "^4",
